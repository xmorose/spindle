PORT=3590
# Shared secret the plugin must send in the X-Spindle-Secret header (e.g. openssl rand -hex 32)
INGEST_SECRET=
# Path to Spindle's own event store (created if missing)
STATS_DB_PATH=./data/stats.db
# Read-only path to Navidrome's database.
# Local dev: point this at a local copy of navidrome.db. Under Docker this is set
# by docker-compose (to /nddata/navidrome.db), so the value here is dev-only.
NAVIDROME_DB_PATH=./navidrome.db
# Required: your Navidrome login name. The dashboard only shows this user's plays.
DEFAULT_USER=
# Session gap threshold in minutes
SESSION_GAP_MINUTES=30

# --- Auth (frontend login gate) ---
# Generate with:  npm run hash-password -- "your long passphrase"
SPINDLE_PASSWORD_HASH=
# Random secret for signing session cookies (e.g. openssl rand -hex 32)
SESSION_SECRET=
# Set false for local http dev so the session cookie is sent without HTTPS
AUTH_COOKIE_SECURE=true
# Session lifetime in days (default 30)
SESSION_DAYS=30
# Set false to disable the login gate entirely
AUTH_ENABLED=true
# Set true when running behind a reverse proxy so the real client IP is used (rate limiting)
TRUST_PROXY=false

# --- Cover art + in-app player (Subsonic) — needs all three of URL/USER/PASSWORD, or these features are off ---
NAVIDROME_URL=http://navidrome:4533
NAVIDROME_USER=your-navidrome-username
NAVIDROME_PASSWORD=
COVER_CACHE_DIR=./data/covers
